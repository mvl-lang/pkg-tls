// pkg.tls.https tests — unit tests for HTTPS URL parsing, request building,
// response parsing, and error handling.
//
// All pure functions tested standalone (no network effects).
// Assurance note: 0 extern blocks.

// ── Type re-declarations (workaround: #96) ────────────────────────────────

type HttpsResponse = struct {
    status_code: Int,
    headers: Map[String, String],
    body: Tainted[String],
}

type HttpsError = enum {
    InvalidUrl(String),
    ConnectionFailed(String),
    InvalidResponse(String),
}

type ParsedHttpsUrl = struct {
    host: String,
    port: Int,
    path: String,
}

// ── Mirrored helpers ────────────────────────────────────────────────────────

fn https_error_msg(e: HttpsError) -> String {
    match e {
        HttpsError::InvalidUrl(msg)       => "invalid URL: ".concat(msg),
        HttpsError::ConnectionFailed(msg)  => "HTTPS connection failed: ".concat(msg),
        HttpsError::InvalidResponse(msg)   => "invalid response: ".concat(msg),
    }
}

fn validate_port(port: Int) -> Result[Int, HttpsError] {
    if port < 1 || port > 65535 {
        Err(HttpsError::InvalidUrl("port out of range (1-65535)"))
    } else {
        Ok(port)
    }
}

fn parse_https_url(url: String) -> Result[ParsedHttpsUrl, HttpsError] {
    if !url.starts_with("https://") {
        Err(HttpsError::InvalidUrl("only https:// supported"))
    } else {
        let url_len: Int = url.len();
        let rest: String = url.substring(8, url_len);
        let rest_len: Int = rest.len();
        let slash_pos: Option[Int] = rest.find("/");
        let host_port: String = match slash_pos {
            Some(i) => rest.substring(0, i),
            None    => rest.substring(0, rest_len),
        };
        let path: String = match slash_pos {
            Some(i) => rest.substring(i, rest_len),
            None    => "/",
        };
        if host_port.len() == 0 {
            Err(HttpsError::InvalidUrl("empty host"))
        } else {
            let hp_len: Int = host_port.len();
            match host_port.find(":") {
                Some(i) => {
                    let host: String = host_port.substring(0, i);
                    let port_str: String = host_port.substring(i + 1, hp_len);
                    if host.len() == 0 {
                        Err(HttpsError::InvalidUrl("empty host"))
                    } else {
                        match port_str.parse_int() {
                            Ok(raw_port) => {
                                let port: Int = validate_port(raw_port)?;
                                Ok(ParsedHttpsUrl { host: host, port: port, path: path })
                            },
                            Err(_) => Err(HttpsError::InvalidUrl("invalid port")),
                        }
                    }
                },
                None => Ok(ParsedHttpsUrl { host: host_port, port: 443, path: path }),
            }
        }
    }
}

fn build_https_request(method: String, host: String, port: Int, path: String, headers: Map[String, String], body: String) -> String {
    let request_line: String = method
        .concat(" ")
        .concat(path)
        .concat(" HTTP/1.1\r\n");
    let host_val: String = if port != 443 {
        host.concat(":").concat(port.to_string())
    } else {
        host
    };
    let result: ref String = request_line
        .concat("Host: ").concat(host_val).concat("\r\n")
        .concat("Connection: close\r\n");
    for k in headers.keys() {
        match headers.get(k) {
            Some(v) => { result = result.concat(k).concat(": ").concat(v).concat("\r\n") },
            None    => {},
        }
    }
    if body.len() > 0 {
        result = result.concat("Content-Length: ").concat(body.len().to_string()).concat("\r\n")
    } else {}
    result.concat("\r\n").concat(body)
}

fn empty_https_headers() -> Map[String, String] {
    let m: ref Map[String, String] = {"__init__": ""};
    let _: Option[String] = m.remove("__init__");
    m
}

fn require_https_resp(opt: Option[String], msg: String) -> Result[String, HttpsError] {
    match opt {
        Some(v) => Ok(v),
        None    => Err(HttpsError::InvalidResponse(msg)),
    }
}

fn parse_https_status_code(s: String) -> Result[Int, HttpsError] {
    match s.parse_int() {
        Ok(c)  => Ok(c),
        Err(_) => Err(HttpsError::InvalidResponse("non-numeric status code")),
    }
}

fn parse_https_headers(lines: List[String]) -> Map[String, String] {
    let m: ref Map[String, String] = empty_https_headers();
    for line in lines {
        match line.find(":") {
            None    => {},
            Some(i) => {
                let k: String = line.substring(0, i).trim().to_lower();
                let v: String = line.substring(i + 1, line.len()).trim();
                if k.len() > 0 { m.insert(k, v) } else {}
            },
        }
    }
    m
}

fn parse_https_response(raw: String) -> Result[HttpsResponse, HttpsError] {
    let lines: List[String] = raw.split("\r\n");
    let status_line: String = require_https_resp(lines.get(0), "empty response")?;
    let parts: List[String] = status_line.split(" ");
    let code_str: String = require_https_resp(parts.get(1), "malformed status line")?;
    let code: Int = parse_https_status_code(code_str)?;
    let n: Int = lines.len();
    let blank_idx: ref Int = n;
    let found_blank: ref Bool = false;
    let idx: ref Int = 1;
    for line in lines.slice(1, n) {
        if !found_blank && line.len() == 0 {
            blank_idx = idx;
            found_blank = true
        } else {}
        idx = idx + 1
    }
    let header_lines: List[String] = if found_blank && blank_idx > 1 {
        lines.slice(1, blank_idx)
    } else {
        []
    };
    let headers: Map[String, String] = parse_https_headers(header_lines);
    let body_str: String = if found_blank && blank_idx + 1 < n {
        let body_lines: List[String] = lines.slice(blank_idx + 1, n);
        let acc: ref String = "";
        let body_first: ref Bool = true;
        for bl in body_lines {
            if body_first {
                acc = bl.concat("");
                body_first = false
            } else {
                acc = acc.concat("\r\n").concat(bl)
            }
        }
        acc
    } else {
        ""
    };
    let body: Tainted[String] = relabel taint(body_str, "HTTPS-RESPONSE-BODY");
    Ok(HttpsResponse { status_code: code, headers: headers, body: body })
}

// ── Mirrored validation helpers (from https.mvl) ────────────────────────────

fn contains_crlf(s: String) -> Bool {
    s.contains("\r") || s.contains("\n")
}

fn validate_no_crlf(s: String, context: String) -> Result[Unit, HttpsError] {
    if contains_crlf(s) {
        Err(HttpsError::InvalidUrl(context.concat(" contains CR/LF")))
    } else {
        Ok(())
    }
}

fn validate_https_headers(headers: Map[String, String]) -> Result[Unit, HttpsError] {
    let valid: ref Bool = true;
    for k in headers.keys() {
        if valid && contains_crlf(k) {
            valid = false
        } else {
            match headers.get(k) {
                Some(v) => if valid && contains_crlf(v) {
                    valid = false
                } else {},
                None => {},
            }
        }
    }
    if valid {
        Ok(())
    } else {
        Err(HttpsError::InvalidUrl("header contains CR/LF"))
    }
}

// ── URL parsing tests ───────────────────────────────────────────────────────

test fn parse_url_simple_host() -> Unit {
    match parse_https_url("https://example.com/path") {
        Err(_)  => assert(false),
        Ok(url) => {
            assert_eq(url.host, "example.com");
            assert_eq(url.port, 443);
            assert_eq(url.path, "/path")
        },
    }
}

test fn parse_url_with_port() -> Unit {
    match parse_https_url("https://localhost:8443/api") {
        Err(_)  => assert(false),
        Ok(url) => {
            assert_eq(url.host, "localhost");
            assert_eq(url.port, 8443);
            assert_eq(url.path, "/api")
        },
    }
}

test fn parse_url_no_path() -> Unit {
    match parse_https_url("https://example.com") {
        Err(_)  => assert(false),
        Ok(url) => {
            assert_eq(url.host, "example.com");
            assert_eq(url.path, "/")
        },
    }
}

test fn parse_url_with_query_string() -> Unit {
    match parse_https_url("https://api.example.com/search?q=hello") {
        Err(_)  => assert(false),
        Ok(url) => {
            assert_eq(url.host, "api.example.com");
            assert_eq(url.path, "/search?q=hello")
        },
    }
}

test fn parse_url_rejects_http() -> Unit {
    match parse_https_url("http://example.com") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn parse_url_rejects_empty_host() -> Unit {
    match parse_https_url("https:///path") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn parse_url_rejects_no_scheme() -> Unit {
    match parse_https_url("example.com") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn parse_url_rejects_invalid_port() -> Unit {
    match parse_https_url("https://example.com:abc/path") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

// ── Request building tests ──────────────────────────────────────────────────

test fn build_get_request_default_port() -> Unit {
    let hdrs: Map[String, String] = empty_https_headers();
    let req: String = build_https_request("GET", "example.com", 443, "/", hdrs, "");
    assert_eq(req.starts_with("GET / HTTP/1.1\r\n"), true);
    assert_eq(req.contains("Host: example.com\r\n"), true);
    assert_eq(req.contains("Connection: close\r\n"), true)
}

test fn build_get_request_non_default_port() -> Unit {
    let hdrs: Map[String, String] = empty_https_headers();
    let req: String = build_https_request("GET", "example.com", 8443, "/api", hdrs, "");
    assert_eq(req.contains("Host: example.com:8443\r\n"), true)
}

test fn build_post_request_with_body() -> Unit {
    let hdrs: Map[String, String] = {"Content-Type": "application/json"};
    let req: String = build_https_request("POST", "api.example.com", 443, "/v1/messages", hdrs, "{\"model\":\"claude\"}");
    assert_eq(req.starts_with("POST /v1/messages HTTP/1.1\r\n"), true);
    assert_eq(req.contains("Content-Length: 18\r\n"), true)
}

test fn build_request_no_content_length_for_empty_body() -> Unit {
    let hdrs: Map[String, String] = empty_https_headers();
    let req: String = build_https_request("GET", "example.com", 443, "/", hdrs, "");
    assert_eq(req.contains("Content-Length"), false)
}

// ── Response parsing tests ──────────────────────────────────────────────────

test fn parse_simple_200_response() -> Unit {
    match parse_https_response("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\nhello") {
        Err(_)  => assert(false),
        Ok(resp) => {
            assert_eq(resp.status_code, 200);
            assert_eq(relabel trust(resp.body, "TEST"), "hello")
        },
    }
}

test fn parse_response_headers_lowercased() -> Unit {
    match parse_https_response("HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nX-Custom: foo\r\n\r\nbody") {
        Err(_)  => assert(false),
        Ok(resp) => {
            assert_eq(resp.headers.contains_key("content-type"), true);
            assert_eq(resp.headers.contains_key("x-custom"), true)
        },
    }
}

test fn parse_response_empty_body() -> Unit {
    match parse_https_response("HTTP/1.1 204 No Content\r\n\r\n") {
        Err(_)  => assert(false),
        Ok(resp) => {
            assert_eq(resp.status_code, 204);
            assert_eq(relabel trust(resp.body, "TEST"), "")
        },
    }
}

test fn parse_response_empty_is_error() -> Unit {
    match parse_https_response("") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidResponse(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn parse_response_malformed_status_is_error() -> Unit {
    match parse_https_response("GARBAGE") {
        Ok(_)  => assert(false),
        Err(HttpsError::InvalidResponse(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn parse_response_body_is_tainted() -> Unit {
    match parse_https_response("HTTP/1.1 200 OK\r\n\r\nsecret data") {
        Err(_)  => assert(false),
        Ok(resp) => {
            let trusted: String = relabel trust(resp.body, "TEST-VALIDATE");
            assert_eq(trusted, "secret data")
        },
    }
}

// ── Error message tests ─────────────────────────────────────────────────────

test fn error_msg_invalid_url() -> Unit {
    assert_eq(https_error_msg(HttpsError::InvalidUrl("bad")), "invalid URL: bad")
}

test fn error_msg_connection_failed() -> Unit {
    assert_eq(https_error_msg(HttpsError::ConnectionFailed("refused")), "HTTPS connection failed: refused")
}

test fn error_msg_invalid_response() -> Unit {
    assert_eq(https_error_msg(HttpsError::InvalidResponse("empty")), "invalid response: empty")
}

// ── CRLF injection validation tests ─────────────────────────────────────────

test fn validate_headers_rejects_crlf_in_key() -> Unit {
    let hdrs: Map[String, String] = {"X-Evil\r\nFoo": "val"};
    match validate_https_headers(hdrs) {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn validate_headers_rejects_crlf_in_value() -> Unit {
    let hdrs: Map[String, String] = {"X-Header": "val\r\nInjected: x"};
    match validate_https_headers(hdrs) {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn validate_headers_rejects_cr_alone_in_key() -> Unit {
    let hdrs: Map[String, String] = {"Key\rFoo": "val"};
    match validate_https_headers(hdrs) {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn validate_headers_rejects_lf_alone_in_value() -> Unit {
    let hdrs: Map[String, String] = {"Key": "val\nfoo"};
    match validate_https_headers(hdrs) {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(_)) => assert(true),
        Err(_) => assert(false),
    }
}

test fn validate_headers_accepts_clean_headers() -> Unit {
    let hdrs: Map[String, String] = {"Content-Type": "application/json", "Accept": "*/*"};
    match validate_https_headers(hdrs) {
        Ok(_) => assert(true),
        Err(_) => assert(false),
    }
}

test fn validate_no_crlf_rejects_method_with_crlf() -> Unit {
    match validate_no_crlf("GET\r\nHost: evil.com", "method") {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(msg)) => assert_eq(msg, "method contains CR/LF"),
        Err(_) => assert(false),
    }
}

test fn validate_no_crlf_accepts_clean_string() -> Unit {
    match validate_no_crlf("GET", "method") {
        Ok(_) => assert(true),
        Err(_) => assert(false),
    }
}

// ── Port range validation tests ─────────────────────────────────────────────

test fn parse_url_rejects_port_zero() -> Unit {
    match parse_https_url("https://example.com:0/path") {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(msg)) => assert_eq(msg, "port out of range (1-65535)"),
        Err(_) => assert(false),
    }
}

test fn parse_url_rejects_port_out_of_range() -> Unit {
    match parse_https_url("https://example.com:99999/path") {
        Ok(_) => assert(false),
        Err(HttpsError::InvalidUrl(msg)) => assert_eq(msg, "port out of range (1-65535)"),
        Err(_) => assert(false),
    }
}

test fn parse_url_accepts_port_443() -> Unit {
    match parse_https_url("https://example.com:443/path") {
        Err(_) => assert(false),
        Ok(url) => assert_eq(url.port, 443),
    }
}

test fn parse_url_accepts_port_1() -> Unit {
    match parse_https_url("https://example.com:1/path") {
        Err(_) => assert(false),
        Ok(url) => assert_eq(url.port, 1),
    }
}

test fn parse_url_accepts_port_65535() -> Unit {
    match parse_https_url("https://example.com:65535/path") {
        Err(_) => assert(false),
        Ok(url) => assert_eq(url.port, 65535),
    }
}
