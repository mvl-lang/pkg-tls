// pkg.tls tests — unit tests for TLS error formatting and type construction.
//
// Network-dependent tests (actual TLS connections) are integration tests
// and run only when a network target is available. These tests cover
// the pure MVL logic: error construction, message formatting, and
// type invariants.
//
// Assurance note: 0 extern blocks (tests the public API layer only).

// ── Type re-declarations (workaround: #96) ────────────────────────────────

type TlsStream = struct {
    _handle: Int,
}

type TlsError = enum {
    HandshakeFailed(String),
    CertificateInvalid(String),
    ConnectionClosed,
    IoError(String),
    Other(String),
}

// ── Mirrored helpers ────────────────────────────────────────────────────────

fn tls_error_msg(e: TlsError) -> String {
    match e {
        TlsError::HandshakeFailed(msg)    => "TLS handshake failed: ".concat(msg),
        TlsError::CertificateInvalid(msg) => "certificate invalid: ".concat(msg),
        TlsError::ConnectionClosed        => "TLS connection closed",
        TlsError::IoError(msg)            => "TLS I/O error: ".concat(msg),
        TlsError::Other(msg)              => "TLS error: ".concat(msg),
    }
}

// ── Error message tests ─────────────────────────────────────────────────────

test fn error_msg_handshake_failed() -> Unit {
    assert_eq(
        tls_error_msg(TlsError::HandshakeFailed("protocol version mismatch")),
        "TLS handshake failed: protocol version mismatch"
    )
}

test fn error_msg_certificate_invalid() -> Unit {
    assert_eq(
        tls_error_msg(TlsError::CertificateInvalid("expired")),
        "certificate invalid: expired"
    )
}

test fn error_msg_connection_closed() -> Unit {
    assert_eq(
        tls_error_msg(TlsError::ConnectionClosed),
        "TLS connection closed"
    )
}

test fn error_msg_io_error() -> Unit {
    assert_eq(
        tls_error_msg(TlsError::IoError("broken pipe")),
        "TLS I/O error: broken pipe"
    )
}

test fn error_msg_other() -> Unit {
    assert_eq(
        tls_error_msg(TlsError::Other("unknown")),
        "TLS error: unknown"
    )
}

// ── Type construction tests ─────────────────────────────────────────────────

test fn tls_stream_handle_round_trip() -> Unit {
    let stream: TlsStream = TlsStream { _handle: 42 };
    assert_eq(stream._handle, 42)
}

test fn tls_error_variants_are_distinct() -> Unit {
    let e1: TlsError = TlsError::HandshakeFailed("a");
    let e2: TlsError = TlsError::CertificateInvalid("a");
    let e3: TlsError = TlsError::ConnectionClosed;
    let e4: TlsError = TlsError::IoError("a");
    let e5: TlsError = TlsError::Other("a");
    // Each produces a different message prefix
    assert_eq(tls_error_msg(e1).starts_with("TLS handshake"), true);
    assert_eq(tls_error_msg(e2).starts_with("certificate"), true);
    assert_eq(tls_error_msg(e3).starts_with("TLS connection"), true);
    assert_eq(tls_error_msg(e4).starts_with("TLS I/O"), true);
    assert_eq(tls_error_msg(e5).starts_with("TLS error"), true)
}
